{
  "name": "oasis",
  "private": true,
  "version": "1.1.5",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "electron": "electron .",
    "electron:dev": "concurrently -k -n vite,electron \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:build": "vite build && electron-builder",
    "installer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "build:extension": "node scripts/build-extension.mjs"
  },
  "build": {
    "appId": "com.spatialfoundry.palma",
    "productName": "Palma",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!**/node_modules/@tauri-apps/**"
    ],
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "afterPack": "scripts/after-pack.cjs",
    "win": {
      "target": "nsis",
      "icon": "src-tauri/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "include": "scripts/installer.nsh",
      "artifactName": "Palma-Setup.${ext}"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://REPLACE-WITH-YOUR-RELEASE-HOST/palma/"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@fontsource/dm-serif-display": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.7",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "framer-motion": "^11.3.8",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.0",
    "wait-on": "^9.0.10",
    "zustand": "^4.5.4"
  }
}
